{
    "name": "github-portfolio-analysis-tool",
    "version": "1.0.0",
    "description": "Run backend and client concurrently",
    "scripts": {
        "dev": "concurrently \"npm run dev:backend\" \"npm run dev:client\"",
        "dev:backend": "cd backend && uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
        "dev:client": "cd client && npm run dev",
        "install:all": "npm install && cd client && npm install && cd ../backend && pip install -r requirements.txt"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}